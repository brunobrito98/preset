{
  "name": "preset-autosystem",
  "version": "1.0.0",
  "bin": "start-horustech.js",
  "scripts": {
    "proxy": "node ws-proxy.js",
    "start": "node start-horustech.js",
    "build:exe": "pkg . --targets node12-win-x64 --output dist/preset-autosystem.exe",
    "build:exe:icon": "node apply-exe-icon.js",
    "build:installer": "npm run build:exe && ISCC preset-autosystem-installer.iss",
    "build:w7": "pkg . --targets node12-win-x64 --output dist/preset-autosystem-w7.exe",
    "build:w11": "pkg . --targets node18-win-x64 --output dist/preset-autosystem-w11.exe",
    "installer:w7": "npm run build:w7 && ISCC preset-autosystem-installer-w7.iss",
    "installer:w11": "npm run build:w11 && ISCC preset-autosystem-installer-w11.iss",
    "build:all": "npm run installer:w7 && npm run installer:w11"
  },
  "pkg": {
    "assets": [
      "preset-autosystem.html"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "ws": "^7.5.10"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "rcedit": "^5.0.2"
  }
}